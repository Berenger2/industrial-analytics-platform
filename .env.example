# Copy this file to .env before starting the project.
# Never commit .env or replace these placeholders with real secrets here.

# PostgreSQL
POSTGRES_DB=industrial_analytics
POSTGRES_USER=industrial
POSTGRES_PASSWORD=change-me-with-a-long-random-password
POSTGRES_PORT=5432

# Cube
CUBE_PORT=4000
CUBEJS_API_SECRET=change-me-with-a-long-random-secret
CUBEJS_DEV_MODE=true

# Frontend
FRONTEND_PORT=5173
VITE_CUBE_API_URL=http://localhost:4000/cubejs-api/v1

# Importer
IMPORT_SOURCE_SYSTEM=sample-files
IMPORT_SITES_FILE=sites.csv
IMPORT_PRODUCTS_FILE=products.csv
IMPORT_PRODUCTION_ORDERS_FILE=production_orders.csv
IMPORT_QUALITY_CONTROLS_FILE=quality_controls.xml
IMPORT_QUALITY_CONTROL_RECORD_TAG=quality_control
IMPORT_CSV_DELIMITER=,
IMPORT_BATCH_SIZE=500
IMPORT_MAX_ERROR_DETAILS=20
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_APPLICATION_NAME=industrial-analytics-importer
LOG_LEVEL=INFO
